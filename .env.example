# ============================================================
# Agentic Crypto Trading Framework — Environment Config
# cp .env.example .env  →  fill in your values
# NEVER commit .env to git!
# ============================================================

# ── Mode ─────────────────────────────────────────────────
# paper | live
TRADE_MODE=paper
LOG_LEVEL=INFO

# ── Exchange ─────────────────────────────────────────────
# Bybit (spot + derivatives, goede WebSocket API)
EXCHANGE=bybit
EXCHANGE_API_KEY=             # https://bybit.com → Account → API Management
EXCHANGE_API_SECRET=

# Voor Stap 5 (Live/Demo Trading)
BYBIT_API_KEY=                # Dezelfde als hierboven, of specifiek voor Bybit
BYBIT_API_SECRET=
BYBIT_TESTNET=false           # 'true' voor Developer Testnet, 'false' voor Main/Demo site
BYBIT_DEMO=true               # 'true' als je de nieuwe 'Demo Trading' op de hoofd-site gebruikt
# Symbols to trade (comma-separated)
SYMBOLS=BTC/USDT,ETH/USDT
TIMEFRAME=1h

# ── LLM — Ollama (local) ─────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b          # auto-set by setup_server.sh

# ── LLM — Cloud Analysts ─────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=             # platform.deepseek.com
XAI_API_KEY=                  # console.x.ai  (Grok)

# ── Search APIs (NewsAnalyst) ──────────────────────────────
BRAVE_SEARCH_API_KEY=          # https://api.search.brave.com
TAVILY_API_KEY=                # https://tavily.com

# ── Discord Notifications ─────────────────────────────────
DISCORD_WEBHOOK_URL=           # Preferred: channel → Integrations → Webhooks → copy URL
DISCORD_BOT_TOKEN=             # Fallback: bot token (keep secret, never share!)
DISCORD_CHANNEL_ID=            # Only needed with bot token

# ── Free Market Data ──────────────────────────────────────
# Coinglass: funding rates, liquidations, long/short ratio (gratis)
COINGLASS_API_KEY=             # https://coinglass.com/pricing (free tier)
# Alternatief.me Fear & Greed: helemaal gratis, geen key nodig

# ── Database ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trade_db
DB_USER=trader
DB_PASSWORD=change_me_strong_password

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── ChromaDB ─────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── Portfolio Risk Management ─────────────────────────────
MAX_RISK_PER_TRADE_PCT=2.0
MAX_OPEN_POSITIONS=3        # Max gelijktijdige posities
MAX_SAME_SYMBOL=1           # Max posities per symbool
MIN_CONFIDENCE=7            # Minimum analyst confidence (0-10)
DAILY_DRAWDOWN_LIMIT=-0.05  # Circuit breaker bij -5% dag verlies
PAPER_STARTING_BALANCE=10000

# ── Event-Driven Scanner ──────────────────────────────────
SCAN_INTERVAL=300           # Scan interval in seconden (5 min)
SCAN_TRIGGERS=2             # Aantal triggers nodig om pipeline te starten
SCAN_COOLDOWN_MIN=30        # Cooldown per symbool in minuten
SCAN_MAX_PER_DAY=4          # Max pipeline runs per dag per symbool
SCAN_HOURLY_FALLBACK=true   # Altijd 1x/uur draaien als safety net
SCAN_VOL_SPIKE=1.5          # Volume spike drempel (150% van gemiddelde)
SCAN_RSI_LOW=35             # RSI oversold drempel
SCAN_RSI_HIGH=65            # RSI overbought drempel
SCAN_LEVEL_DIST=0.005       # Afstand tot key level (0.5%)
SCAN_FUNDING=0.0005         # Funding rate threshold (0.05%)

# ── API Server ────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change_me_random_secret
